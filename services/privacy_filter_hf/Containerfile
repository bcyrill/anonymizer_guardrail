# syntax=docker/dockerfile:1.7
# Privacy-filter-HF inference service (experimental).
#
# A second variant of services/privacy_filter/ that pairs HuggingFace's
# AutoModelForTokenClassification (forward pass) with opf's
# ViterbiCRFDecoder (constrained BIOES decode). The hypothesis under
# test: HF Transformers' loader gets us better-tuned CPU inference
# kernels than opf's from-scratch Transformer reimplementation, while
# opf's Viterbi keeps span-quality parity (tight boundaries, no
# over-merges across `\n\n`). See COMPARE.md for the measurement
# context.
#
# Wire-format-compatible with services/privacy_filter/: same /detect
# request and response shapes (raw opf-vocabulary labels —
# `private_email`, `private_person`, etc.), so the guardrail's
# RemotePrivacyFilterDetector talks to either with no client changes.
#
# Default port 8003. The original opf-only service is on 8001. Both can
# run side-by-side on the same docker network for A/B benchmarks.
#
# Single flavour: model downloads from HF Hub on first container start
# (mount a named volume at /app/.cache/huggingface for persistence).
# A baked-in variant was prototyped and dropped — the build hits
# disk-space pressure during the layer commit (transformers +
# opf + ~3 GB of weights, with overlayfs duplicating cached files
# via snapshot symlinks, balloons the working set well past the
# image's nominal size). The opf-only service still ships a baked
# variant for air-gapped runs; for HF, depend on a pre-populated
# bind mount or a sidecar that pre-fetches the model.
#
# Build:
#   podman build -t privacy-filter-hf-service:cpu \
#       -f services/privacy_filter_hf/Containerfile services/privacy_filter_hf/
#
# Run (runtime download from HF Hub on first call):
#   podman volume create privacy-filter-hf-cache
#   podman run --rm -p 8003:8003 \
#       -v privacy-filter-hf-cache:/app/.cache/huggingface \
#       privacy-filter-hf-service:cpu

FROM docker.io/library/python:3.12-slim

LABEL org.opencontainers.image.title="privacy-filter-hf-service" \
      org.opencontainers.image.description="HF-pipeline-based forward + opf Viterbi decoder for openai/privacy-filter" \
      org.opencontainers.image.licenses="MIT"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# curl for HEALTHCHECK; git for the opf install (same rationale as the
# opf-only service: opf isn't on PyPI, only on GitHub).
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
 && apt-get update \
 && apt-get install -y --no-install-recommends curl git

# Non-root user.
ARG APP_UID=10001
ARG APP_GID=10001
RUN groupadd --system --gid ${APP_GID} app \
 && useradd  --system --uid ${APP_UID} --gid ${APP_GID} \
             --home-dir /app --shell /usr/sbin/nologin app

WORKDIR /app

ARG TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
# Pinned opf commit — same as services/privacy_filter/Containerfile so
# both variants decode against identical Viterbi logic + transition
# constraints. Bump this in lockstep with the opf-only image.
ARG OPF_GIT_REF=f7f00ca7fb86
# `TARGET_DEVICE` baked into PRIVACY_FILTER_DEVICE env so the runtime
# default matches the wheel index. CPU images (default) keep
# device=cpu; cu130 images pass --build-arg TARGET_DEVICE=cuda from
# the image_builder's flavour config. Operators can still override at
# run time via `-e PRIVACY_FILTER_DEVICE=…`. Mirrors the opf-only
# Containerfile's pattern so both variants share the same operator
# experience for device selection.
ARG TARGET_DEVICE=cpu

# transformers must be 5.7.0+ — that's the first stable release with
# `OpenAIPrivacyFilterForTokenClassification` registered in the model
# zoo. Earlier versions can't load the architecture and fall back to
# `trust_remote_code=True`, which the model card doesn't ship.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --index-url "$TORCH_INDEX_URL" torch \
 && pip install \
        'transformers>=5.7.0' \
        'safetensors' \
        "git+https://github.com/openai/privacy-filter@${OPF_GIT_REF}" \
        'fastapi>=0.110' \
        'uvicorn[standard]>=0.27' \
        'pydantic>=2.6'

COPY main.py /app/main.py

# HuggingFace's snapshot_download writes to ~/.cache/huggingface/hub/
# by default. Mount the persistent cache here so the model survives
# container recreation. Different mount path from the opf-only service
# (which uses /app/.opf/) — these caches are NOT interchangeable;
# different file layouts.
RUN mkdir -p /app/.cache/huggingface \
 && chown -R app:app /app/.cache

ENV HOST=0.0.0.0 \
    PORT=8003 \
    LOG_LEVEL=info \
    MODEL_NAME=openai/privacy-filter \
    PRIVACY_FILTER_DEVICE=$TARGET_DEVICE

EXPOSE 8003

USER app

# Generous start-period to accommodate the runtime-download case
# (~3 GB safetensors plus the 28 MB tokenizer.json). On a slow
# network the first start can take several minutes.
HEALTHCHECK --interval=15s --timeout=5s --start-period=300s --retries=3 \
    CMD curl -fsS "http://127.0.0.1:${PORT}/health" | grep -q '"status":"ok"' || exit 1

CMD ["sh", "-c", "exec uvicorn main:app --host ${HOST} --port ${PORT} --log-level $(echo ${LOG_LEVEL} | tr A-Z a-z)"]
